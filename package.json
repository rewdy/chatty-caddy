{
  "name": "@rewdy/chatty-caddy",
  "version": "0.1.0",
  "description": "A CLI notebook for storing and running AI prompts",
  "module": "src/cli.ts",
  "type": "module",
  "private": false,
  "bin": {
    "chatty-caddy": "./src/cli.ts",
    "chaca": "./src/cli.ts"
  },
  "scripts": {
    "build": "bun build.ts",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt src",
    "start": "bun src/cli.ts",
    "dev": "bun src/cli.ts"
  },
  "dependencies": {
    "@clack/prompts": "1.2.0",
    "chalk": "5.6.2",
    "fuse.js": "7.3.0",
    "gray-matter": "4.0.3",
    "ink": "7.0.1",
    "ink-text-input": "6.0.0",
    "react": "19.2.5",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "19.2.14",
    "oxfmt": "0.46.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "patchedDependencies": {
    "ink@7.0.1": "patches/ink@7.0.1.patch"
  }
